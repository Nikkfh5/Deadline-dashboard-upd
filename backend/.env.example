# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=deadline_tracker

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Environment
ENVIRONMENT=development

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Userbot (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Generate with: python scripts/generate_session.py
TELEGRAM_SESSION_STRING=

# Anthropic API (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Frontend URL (for dashboard links in bot messages)
FRONTEND_URL=http://localhost:3000
